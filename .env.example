# =============================================
# CONFIGURATION DU BACKEND
# =============================================

# Flask
FLASK_APP=Backend/app.py
FLASK_ENV=development
FLASK_DEBUG=1

# Sécurité
SECRET_KEY=votre_cle_secrete_tres_longue_et_complexe_change_en_production
JWT_SECRET_KEY=votre_jwt_secret_tres_long_change_en_production
ADMIN_TOKEN=admin-secret-token-change-en-production

# MongoDB
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/movie_recommender?retryWrites=true&w=majority
MONGO_URI_DEV=mongodb://localhost:27017/movie_recommender_dev

# Port et Host
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5000

# Configuration du système de recommandation
RECOMMENDATION_N_CLUSTERS=5
RECOMMENDATION_SIMILARITY_THRESHOLD=0.1
RECOMMENDATION_MIN_RATINGS=5

# Chemins de sauvegarde
MODEL_SAVE_PATH=./models
DATA_SAVE_PATH=./data

# =============================================
# CONFIGURATION DU FRONTEND
# =============================================

REACT_APP_API_URL=http://localhost:5000
REACT_APP_API_TIMEOUT=30000
